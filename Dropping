<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>DropDone - Digital Store</title>

<style>
body {
  margin: 0;
  font-family: Arial, sans-serif;
}

/* HEADER */
header {
  background: #222;
  color: white;
  padding: 15px;
  text-align: center;
}

nav {
  background: #333;
  text-align: center;
  padding: 10px;
}

nav a {
  color: white;
  text-decoration: none;
  margin: 10px;
  font-size: 14px;
}

/* HERO */
.hero {
  text-align: center;
  padding: 50px;
  background: #cfe0e8;
}

.hero h1 {
  font-size: 40px;
}

.hero p {
  color: gray;
}

/* PRODUCTS */
.products {
  padding: 30px;
  text-align: center;
}

.products h2 {
  margin-bottom: 20px;
}

.product-container {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
}

.product {
  border: 1px solid #ddd;
  margin: 10px;
  padding: 15px;
  width: 200px;
}

.product img {
  width: 100%;
}

.price {
  color: red;
  font-weight: bold;
}

/* ABOUT */
.about {
  background: #222;
  color: white;
  padding: 40px;
  text-align: center;
}

/* FOOTER */
footer {
  background: #111;
  color: white;
  text-align: center;
  padding: 10px;
}
</style>

</head>

<body>

<!-- HEADER -->
<header>
  <h2>dropdone</h2>
</header>

<nav>
  <a href="#">Home</a>
  <a href="#">Products</a>
  <a href="#">About</a>
  <a href="#">Contact</a>
</nav>

<!-- HERO SECTION -->
<section class="hero">
  <h1>Elite Gear for Elite Athletes</h1>
  <p>Where performance meets style. Designed for champions.</p>
</section>

<!-- PRODUCTS -->
<section class="products">
  <h2>Our Products</h2>

  <div class="product-container">

    <!-- PRODUCT 1 -->
    <div class="product">
      <img src="https://via.placeholder.com/200" alt="T-Shirt">
      <h4>Red T-Shirt</h4>
      <p class="price">₹500</p>
    </div>

    <!-- PRODUCT 2 -->
    <div class="product">
      <img src="https://via.placeholder.com/200" alt="Shoes">
      <h4>Sports Shoes</h4>
      <p class="price">₹1500</p>
    </div>

    <!-- PRODUCT 3 -->
    <div class="product">
      <img src="https://via.placeholder.com/200" alt="Headphones">
      <h4>Headphones</h4>
      <p class="price">₹2000</p>
    </div>

    <!-- PRODUCT 4 -->
    <div class="product">
      <img src="https://via.placeholder.com/200" alt="Watch">
      <h4>Smart Watch</h4>
      <p class="price">₹2500</p>
    </div>

  </div>
</section>

<!-- ABOUT -->
<section class="about">
  <h2>About Us</h2>
  <p>
    DropDone is a beginner-level dropshipping website created using only HTML and CSS.
    This project showcases basic web design skills including layout, product display,
    and responsive structure without using JavaScript.
  </p>
</section>

<!-- FOOTER -->
<footer>
  <p>© 2026 DropDone. All Rights Reserved.</p>
</footer>

</body>
</html>
